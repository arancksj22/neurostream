# Copy to `.env` and fill in real values.
# Do NOT commit `.env`.

# Service identity (optional)
MS3_SERVICE_NAME=neurostream-ms3

# Postgres (preferred). Leave blank to use in-memory fallback (if enabled).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/neurostream

# Callback target
MS4_BASE_URL=http://localhost:8004

# Embeddings
EMBEDDING_DIMENSIONS=768

# Search defaults
SEARCH_DEFAULT_LIMIT=5
SEARCH_MAX_LIMIT=20

# Development toggle
# If true and DATABASE_URL is empty/unreachable, MS3 will use an in-memory repository.
ALLOW_IN_MEMORY_FALLBACK=true
