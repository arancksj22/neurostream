# Copy to `.env` and fill in real values.
# Do NOT commit `.env`.

# Service identity (optional)
MS2_SERVICE_NAME=neurostream-ms2

# Redis (Celery broker / job queue)
REDIS_URL=redis://localhost:6379/0

# AWS / S3 (media storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
AWS_REGION=us-east-1

# Google Gemini
GEMINI_API_KEY=
# Used by vision pipeline (leave blank if MOCK_EXTERNAL_SERVICES=true)
GEMINI_VISION_MODEL=
# Default matches code fallback
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# Whisper
WHISPER_MODEL=base

# Downstream callbacks
MS3_BASE_URL=http://localhost:8003
MS4_BASE_URL=http://localhost:8004

# Embeddings
EMBEDDING_DIMENSIONS=768

# Execution toggles
# If true, /process runs pipeline in-process (useful for local dev)
MS2_PROCESS_INLINE=true
# If true, use deterministic mock implementations (no external calls)
MOCK_EXTERNAL_SERVICES=true
