# Copy to `.env` and fill in real values.
# Do NOT commit `.env`.

# Service identity (optional)
MS2_SERVICE_NAME=neurostream-ms2

# Redis (Celery broker / job queue)
REDIS_URL=rediss://default:gQAAAAAAAW-lAAIgcDEyZGJmN2E5ZmUxODg0ZGU1YTI4YThlZWI1ZTYzYjc0ZA@prepared-earwig-94117.upstash.io:6379

# AWS / S3 (media storage)
# Alias support: S3_ACCESS_KEY_ID, S3_SECRET_ACCESS_KEY, AWS_S3_BUCKET
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
AWS_REGION=us-east-1

# Google Gemini
GEMINI_API_KEY=
# Used by vision pipeline (leave blank if MOCK_EXTERNAL_SERVICES=true)
GEMINI_VISION_MODEL=
# Recommended Gemini Developer API text embedding model for per-document retrieval vectors.
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# OpenAI Whisper API for real audio transcription
OPENAI_API_KEY=

# Whisper
WHISPER_MODEL=base

# Downstream callbacks
MS3_BASE_URL=https://neurostream-ciiu.onrender.com
MS4_BASE_URL=https://neurostream-00qg.onrender.com

# Embeddings
EMBEDDING_DIMENSIONS=768

# Execution toggles
# If true, /process runs pipeline in-process (useful for local dev)
MS2_PROCESS_INLINE=true
# Set to false in deployed environments so audio transcription and embeddings are real.
MOCK_EXTERNAL_SERVICES=false
